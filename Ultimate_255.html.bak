// ── SCREEN MANAGEMENT ──
const screenGrammar = document.getElementById('screen-grammar');
const screenSelect  = document.getElementById('screen-select');
const screenStudy   = document.getElementById('screen-study');

function showScreen(name) {
  screenGrammar.classList.remove('active');
  screenSelect.classList.remove('active');
  screenStudy.classList.remove('active');
  if (name === 'grammar') screenGrammar.classList.add('active');
  else if (name === 'select') screenSelect.classList.add('active');
  else if (name === 'study') { screenStudy.style.display = 'flex'; screenStudy.classList.add('active'); }
}

// ── BUILD GRAMMAR GRID ──
const grammarGrid = document.getElementById('grammar-grid');
let currentCategory = null;

categories.forEach(cat => {
  const count = cat.end - cat.start + 1;
  const btn = document.createElement('button');
  btn.className = 'grammar-btn';
  btn.innerHTML = `
    <span class="grammar-btn-count">${count}文</span>
    <span class="grammar-btn-name">${cat.name}</span>
    <span class="grammar-btn-range">No.${cat.start}〜${cat.end}</span>
  `;
  btn.addEventListener('click', () => {
    currentCategory = cat;
    openSelectScreen(cat);
  });
  grammarGrid.appendChild(btn);
});

// ── SELECT SCREEN ──
const cardGrid   = document.getElementById('card-grid');
const countEl    = document.getElementById('select-count');
const startBtn   = document.getElementById('btn-start');
const badgeEl    = document.getElementById('current-grammar-badge');

function openSelectScreen(cat) {
  badgeEl.textContent = cat.name + '　No.' + cat.start + '〜' + cat.end;
  document.getElementById('study-grammar-badge').textContent = cat.name;

  // rebuild grid
  cardGrid.innerHTML = '';
  const items = flashcards.filter(c => c.no >= cat.start && c.no <= cat.end);
  items.forEach(card => {
    const label = document.createElement('label');
    label.className = 'item-label';
    label.innerHTML = `
      <input type="checkbox" data-no="${card.no}">
      <span class="item-num">No.${card.no}</span>
      <span class="item-text">${card.japanese}</span>
    `;
    cardGrid.appendChild(label);
    const cb = label.querySelector('input');
    cb.addEventListener('change', () => {
      label.classList.toggle('checked', cb.checked);
      updateCount();
    });
  });
  updateCount();
  showScreen('select');
}

function updateCount() {
  const n = cardGrid.querySelectorAll('input:checked').length;
  countEl.innerHTML = `<em>${n}</em> 問 選択中`;
  startBtn.disabled = n === 0;
}

document.getElementById('btn-all').addEventListener('click', () => {
  cardGrid.querySelectorAll('input').forEach(cb => {
    cb.checked = true;
    cb.closest('.item-label').classList.add('checked');
  });
  updateCount();
});
document.getElementById('btn-none').addEventListener('click', () => {
  cardGrid.querySelectorAll('input').forEach(cb => {
    cb.checked = false;
    cb.closest('.item-label').classList.remove('checked');
  });
  updateCount();
});

document.getElementById('btn-back-to-grammar').addEventListener('click', () => {
  showScreen('grammar');
});

// ── STUDY LOGIC ──
const japaneseEl = document.getElementById('japanese-text');
const englishEl  = document.getElementById('english-text');
const aCard      = document.getElementById('a-card');
const nextBtn    = document.getElementById('next-button');
const speakBtn   = document.getElementById('speak-button');
const progCur    = document.getElementById('prog-cur');
const progTotal  = document.getElementById('prog-total');
const qNumEl     = document.getElementById('q-num');

let deck = [];
let deckIndex = 0;
let currentCard = null;
let isAnswerShown = false;

const synth = window.speechSynthesis;
let englishVoice = null;
function loadVoice() {
  const voices = synth.getVoices();
  englishVoice = voices.find(v => v.lang === 'en-US') ||
                 voices.find(v => v.lang === 'en-GB') ||
                 voices.find(v => v.lang.startsWith('en'));
}
if (synth.onvoiceschanged !== undefined) synth.onvoiceschanged = loadVoice;
loadVoice();

function speak(text) {
  if (!synth || !text) return;
  if (synth.speaking) synth.cancel();
  const u = new SpeechSynthesisUtterance(text);
  u.lang = 'en-US'; u.rate = 0.9;
  if (englishVoice) u.voice = englishVoice;
  synth.speak(u);
}

function shuffle(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
}

startBtn.addEventListener('click', () => {
  const selected = [];
  cardGrid.querySelectorAll('input:checked').forEach(cb => {
    const card = flashcards.find(c => c.no === +cb.dataset.no);
    if (card) selected.push(card);
  });
  deck = [...selected];
  shuffle(deck);
  deckIndex = 0;
  progTotal.textContent = deck.length;
  showScreen('study');
  showCard();
});

document.getElementById('btn-back').addEventListener('click', () => {
  synth.cancel();
  screenStudy.style.display = 'none';
  showScreen('select');
});

function showCard() {
  currentCard = deck[deckIndex];
  progCur.textContent = deckIndex + 1;
  qNumEl.textContent = 'No.' + currentCard.no;

  japaneseEl.classList.remove('anim');
  void japaneseEl.offsetWidth;
  japaneseEl.classList.add('anim');
  japaneseEl.textContent = currentCard.japanese;

  englishEl.textContent = '';
  aCard.classList.add('hidden-ans');
  speakBtn.classList.remove('visible');
  isAnswerShown = false;
  nextBtn.textContent = '答えを表示';
  if (synth.speaking) synth.cancel();
}

function showAnswer() {
  englishEl.classList.remove('anim');
  void englishEl.offsetWidth;
  englishEl.classList.add('anim');
  englishEl.textContent = currentCard.english;
  aCard.classList.remove('hidden-ans');
  speakBtn.classList.add('visible');
  isAnswerShown = true;
  nextBtn.textContent = deckIndex < deck.length - 1 ? '次の問題 →' : '最初からやり直す';
  speak(currentCard.english);
}

function next() {
  if (!isAnswerShown) { showAnswer(); return; }
  if (deckIndex < deck.length - 1) {
    deckIndex++;
  } else {
    shuffle(deck);
    deckIndex = 0;
  }
  showCard();
}

nextBtn.addEventListener('click', next);
speakBtn.addEventListener('click', () => { if (isAnswerShown) speak(currentCard.english); });

document.addEventListener('keydown', e => {
  if (screenStudy.classList.contains('active')) {
    if (e.key === ' ') { e.preventDefault(); next(); }
    else if (e.key === 'Enter') { e.preventDefault(); if (!isAnswerShown) showAnswer(); }
    else if (e.key === 'Escape') synth.cancel();
  }
});
</script>
</body>
</html>
