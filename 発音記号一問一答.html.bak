<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>IPA Flashcards</title>
<link href="https://fonts.googleapis.com/css2?family=Doulos+SIL&family=Space+Mono:wght@400;700&family=Noto+Sans+JP:wght@300;400;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0a0c10;
    --surface: #111418;
    --border: #1e2530;
    --accent: #00e5ff;
    --accent2: #7c3aed;
    --text-primary: #e8edf5;
    --text-muted: #4a5568;
    --text-hint: #2d3748;
    --glow: 0 0 30px rgba(0,229,255,0.15), 0 0 60px rgba(0,229,255,0.05);
  }

  html, body {
    width: 100%; height: 100%;
    background: var(--bg);
    color: var(--text-primary);
    font-family: 'Noto Sans JP', sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Background grid */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image:
      linear-gradient(rgba(0,229,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* Ambient glow orbs */
  body::after {
    content: '';
    position: fixed;
    top: -20%; left: -10%;
    width: 60vw; height: 60vw;
    background: radial-gradient(circle, rgba(124,58,237,0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .orb2 {
    position: fixed;
    bottom: -20%; right: -10%;
    width: 50vw; height: 50vw;
    background: radial-gradient(circle, rgba(0,229,255,0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .wrapper {
    position: relative;
    z-index: 1;
    width: min(90vw, 720px);
  }

  /* Header */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    padding: 0 4px;
  }

  .header-title {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .header-title span {
    color: var(--accent);
  }

  .counter {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  /* Card */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 60px 60px 48px;
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.4s ease;
  }

  .card.revealed {
    box-shadow: var(--glow);
    border-color: rgba(0,229,255,0.2);
  }

  /* Top line accent */
  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 10%; right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .card.revealed::before { opacity: 0.6; }

  /* IPA Symbol */
  .symbol-wrap {
    text-align: center;
    padding: 20px 0 40px;
    position: relative;
  }

  #symbol {
    font-family: 'Doulos SIL', 'Charis SIL', 'Gentium Plus', 'DejaVu Sans', 'Times New Roman', serif;
    font-size: clamp(64px, 10vw, 120px);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1.1;
    display: block;

    /* Flip-in animation */
    animation: flipIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes flipIn {
    from { transform: rotateX(60deg) scale(0.85); opacity: 0; }
    to   { transform: rotateX(0deg) scale(1);    opacity: 1; }
  }

  /* Divider */
  .divider {
    width: 100%;
    height: 1px;
    background: var(--border);
    margin: 0 0 40px;
    position: relative;
    overflow: hidden;
  }

  .divider::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    transition: left 0.6s ease;
  }

  .card.revealed .divider::after { left: 100%; }

  /* Answer area */
  #answerArea {
    min-height: 90px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  #wordInfo {
    flex: 1;
  }

  .word-en {
    font-family: 'Space Mono', monospace;
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 8px;

    animation: slideUp 0.35s cubic-bezier(0.34, 1.4, 0.64, 1);
  }

  .word-jp {
    font-size: clamp(14px, 2vw, 18px);
    font-weight: 300;
    color: var(--text-muted);
    letter-spacing: 0.1em;

    animation: slideUp 0.4s 0.06s cubic-bezier(0.34, 1.4, 0.64, 1) both;
  }

  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  /* Speaker button */
  #speakerButton {
    width: 56px; height: 56px;
    border-radius: 50%;
    border: 1px solid rgba(0,229,255,0.3);
    background: rgba(0,229,255,0.05);
    color: var(--accent);
    font-size: 22px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;

    animation: fadeIn 0.3s 0.1s both;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.7); }
    to   { opacity: 1; transform: scale(1); }
  }

  #speakerButton:hover {
    background: rgba(0,229,255,0.12);
    box-shadow: 0 0 20px rgba(0,229,255,0.2);
    transform: scale(1.08);
  }

  #speakerButton:active { transform: scale(0.93); }

  #speakerButton.hidden { display: none; }

  /* Footer hint */
  .footer {
    margin-top: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
  }

  .hint {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-hint);
  }

  .key {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #1e2530;
    border-radius: 5px;
    padding: 2px 8px;
    background: #0d1117;
    font-size: 10px;
    color: #2d3748;
    font-family: 'Space Mono', monospace;
  }

  /* Flash on answer reveal */
  @keyframes borderPulse {
    0%   { border-color: rgba(0,229,255,0.6); }
    100% { border-color: rgba(0,229,255,0.2); }
  }

  .card.just-revealed {
    animation: borderPulse 0.5s ease-out forwards;
  }
</style>
</head>
<body>

<div class="orb2"></div>

<div class="wrapper">
  <div class="header">
    <div class="header-title">IPA Flashcards <span>@AVC</span></div>
    <div class="counter" id="counter">—</div>
  </div>

  <div class="card" id="card">
    <div class="symbol-wrap">
      <span id="symbol"></span>
    </div>

    <div class="divider"></div>

    <div id="answerArea">
      <div id="wordInfo"></div>
      <button id="speakerButton" class="hidden" onclick="speakWord()">🔊</button>
    </div>
  </div>

  <div class="footer">
    <div class="hint"><span class="key">Enter</span> 答えを表示 / 次へ</div>
    <div class="hint"><span class="key">Esc</span> 読み上げ停止</div>
  </div>
</div>

<script>
