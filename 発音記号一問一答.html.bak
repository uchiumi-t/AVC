];

let current = null;
let count = 0;
const symbolEl   = document.getElementById("symbol");
const wordInfoEl = document.getElementById("wordInfo");
const speakerBtn = document.getElementById("speakerButton");
const cardEl     = document.getElementById("card");
const counterEl  = document.getElementById("counter");

function showSymbolOnly() {
  const r = Math.floor(Math.random() * words.length);
  current = words[r];
  count++;

  // Reset symbol animation by re-inserting
  symbolEl.style.animation = 'none';
  symbolEl.offsetHeight; // reflow
  symbolEl.style.animation = '';
  symbolEl.textContent = current.symbol;

  wordInfoEl.innerHTML = "";
  speakerBtn.classList.add("hidden");
  cardEl.classList.remove("revealed", "just-revealed");
  counterEl.textContent = `#${count}`;
}

function showAnswer() {
  wordInfoEl.innerHTML = `
    <div class="word-en">${current.word}</div>
    <div class="word-jp">${current.jp}</div>
  `;
  speakerBtn.classList.remove("hidden");
  cardEl.classList.add("revealed", "just-revealed");
  setTimeout(() => cardEl.classList.remove("just-revealed"), 600);
  speakWord();
}

function speakWord() {
  if (!current) return;
  const u = new SpeechSynthesisUtterance(current.word);
  u.lang = 'en-US';
  if (speechSynthesis.speaking) speechSynthesis.cancel();
  speechSynthesis.speak(u);
}

document.addEventListener("keydown", (e) => {
  if (e.key === "Escape") { speechSynthesis.cancel(); return; }
  if (e.key === "Enter") {
    speechSynthesis.cancel();
    wordInfoEl.innerHTML === "" ? showAnswer() : showSymbolOnly();
  }
});

showSymbolOnly();
</script>
</body>
</html>
